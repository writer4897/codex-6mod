<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="12.0" DefaultTargets="Default" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Default</Configuration>
    <Name>Yuri_2.0</Name>
    <Guid>54fdb7a9-f382-4561-91fc-45a91c42eae4</Guid>
    <ProjectGuid>4ef78c1b-a681-4620-bdb9-54ca8d8c3347</ProjectGuid>
    <ModVersion>2</ModVersion>
    <Teaser>Adds Yuri and the Literature Club as a playable civilization.</Teaser>
    <TeaserImage>WorkshopPreview.png</TeaserImage>
    <Description>Adds Yuri and the Literature Club as a playable civilization with a unique leader ability and district.</Description>
    <Authors>31034</Authors>
    <AffectsSavedGames>true</AffectsSavedGames>
    <SupportsSinglePlayer>true</SupportsSinglePlayer>
    <SupportsMultiplayer>true</SupportsMultiplayer>
    <SupportsHotSeat>true</SupportsHotSeat>
    <CompatibleVersions>1.2,2.0</CompatibleVersions>
    <AssociationData><![CDATA[<Associations><Dependency type="Dlc" title="Expansion: Gathering Storm" id="4873eb62-8ccc-4574-b784-dda455e74e68" /></Associations>]]></AssociationData>
    <ActionCriteriaData><![CDATA[<ActionCriteria><Criteria id="YuriCriteria"><LeaderPlayable>Players:Expansion2_Players::LEADER_YURI</LeaderPlayable></Criteria><Criteria id="YuriXP2"><RuleSetInUse>RULESET_EXPANSION_2</RuleSetInUse></Criteria></ActionCriteria>]]></ActionCriteriaData>
    <FrontEndActionData><![CDATA[<FrontEndActions><UpdateDatabase id="Config"><File>Leader/Leader_Config.xml</File><File>Leader/Leader_FrontEnd.sql</File></UpdateDatabase><UpdateColors id="ConfigColors"><File>Leader/Leader_Colors.sql</File></UpdateColors><UpdateText id="ConfigText"><File>Yuri_Text/Yuri_Text_Config.xml</File><File>Yuri_Text/Yuri_Text_Chinese.xml</File><File>Yuri_Text/Yuri_Text_Loading.xml</File></UpdateText><UpdateIcons id="ConfigIcons"><File>Core/NewIcons.xml</File></UpdateIcons><UpdateArt id="ConfigArt"><File>Yuri_2.0.dep</File></UpdateArt></FrontEndActions>]]></FrontEndActionData>
    <InGameActionData><![CDATA[<InGameActions><ImportFiles id="YuriDiplomacyReplacement"><Properties><LoadOrder>2000000000</LoadOrder></Properties><Criteria>YuriXP2</Criteria><File>UI/Replacement/DiplomacyActionView.xml</File><File>UI/Replacement/DiplomacyActionView.lua</File></ImportFiles><UpdateDatabase id="Gameplay"><Criteria>YuriCriteria</Criteria><File>Leader/Yuri_Leaders.xml</File><File>Core/Yuri_Civilization.xml</File><File>Core/Yuri_Civilization_Bonus.sql</File><File>Core/Yuri_District.xml</File><File>Core/Yuri_Units.xml</File><File>Leader/Leader_Screens.sql</File></UpdateDatabase><UpdateColors id="GameplayColors"><Criteria>YuriCriteria</Criteria><File>Leader/Leader_Colors.sql</File></UpdateColors><UpdateText id="GameplayText"><Criteria>YuriCriteria</Criteria><File>Yuri_Text/Yuri_Text_Gameplay.xml</File><File>Yuri_Text/Yuri_Text_Cities.xml</File><File>Yuri_Text/Yuri_Text_Chinese.xml</File><File>Yuri_Text/Yuri_Text_Loading.xml</File></UpdateText><UpdateIcons id="Icons"><Criteria>YuriCriteria</Criteria><File>Core/NewIcons.xml</File></UpdateIcons><UpdateArt id="Art"><Criteria>YuriCriteria</Criteria><File>Yuri_2.0.dep</File></UpdateArt></InGameActions>]]></InGameActionData>
    <AssemblyName>Yuri_2.0</AssemblyName>
    <RootNamespace>Yuri_2.0</RootNamespace>
  </PropertyGroup>
