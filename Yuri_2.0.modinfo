<?xml version="1.0" encoding="utf-8"?>
<Mod id="54fdb7a9-f382-4561-91fc-45a91c42eae4" version="2">
  <Properties>
    <Name>Yuri_2.0</Name>
    <Description>Adds Yuri and the Literature Club as a playable civilization with a unique leader ability and district.</Description>
    <Teaser>Adds Yuri and the Literature Club as a playable civilization.</Teaser>
    <TeaserImage>WorkshopPreview.png</TeaserImage>
    <Authors>31034</Authors>
    <CompatibleVersions>1.2,2.0</CompatibleVersions>
  </Properties>
  <Dependencies>
    <Mod id="4873eb62-8ccc-4574-b784-dda455e74e68" title="Expansion: Gathering Storm" />
  </Dependencies>
  <ActionCriteria>
    <Criteria id="YuriCriteria">
      <LeaderPlayable>Players:Expansion2_Players::LEADER_YURI</LeaderPlayable>
    </Criteria>
    <Criteria id="YuriXP2">
      <RuleSetInUse>RULESET_EXPANSION_2</RuleSetInUse>
    </Criteria>
  </ActionCriteria>
  <FrontEndActions>
    <UpdateDatabase id="Config">
      <File>Leader/Leader_Config.xml</File>
      <File>Leader/Leader_FrontEnd.sql</File>
    </UpdateDatabase>
    <UpdateColors id="ConfigColors">
      <File>Leader/Leader_Colors.sql</File>
    </UpdateColors>
    <UpdateArt id="ConfigArt">
      <File>Yuri_2.0.dep</File>
    </UpdateArt>
    <UpdateText id="ConfigText">
      <File>Yuri_Text/Yuri_Text_Config.xml</File>
      <File>Yuri_Text/Yuri_Text_Chinese.xml</File>
      <File>Yuri_Text/Yuri_Text_Loading.xml</File>
    </UpdateText>
    <UpdateIcons id="ConfigIcons">
      <File>Core/NewIcons.xml</File>
    </UpdateIcons>
  </FrontEndActions>
  <InGameActions>
    <ImportFiles id="YuriDiplomacyReplacement">
      <Properties>
        <LoadOrder>2000000000</LoadOrder>
      </Properties>
      <Criteria>YuriXP2</Criteria>
      <File>UI/Replacement/DiplomacyActionView.xml</File>
      <File>UI/Replacement/DiplomacyActionView.lua</File>
    </ImportFiles>
    <UpdateDatabase id="Gameplay">
      <Criteria>YuriCriteria</Criteria>
      <File>Leader/Yuri_Leaders.xml</File>
      <File>Core/Yuri_Civilization.xml</File>
      <File>Core/Yuri_Civilization_Bonus.sql</File>
      <File>Core/Yuri_District.xml</File>
      <File>Core/Yuri_Units.xml</File>
      <File>Leader/Leader_Screens.sql</File>
    </UpdateDatabase>
    <UpdateColors id="GameplayColors">
      <Criteria>YuriCriteria</Criteria>
      <File>Leader/Leader_Colors.sql</File>
    </UpdateColors>
    <UpdateArt id="Art">
      <Criteria>YuriCriteria</Criteria>
      <File>Yuri_2.0.dep</File>
    </UpdateArt>
    <UpdateText id="GameplayText">
      <Criteria>YuriCriteria</Criteria>
      <File>Yuri_Text/Yuri_Text_Gameplay.xml</File>
      <File>Yuri_Text/Yuri_Text_Cities.xml</File>
      <File>Yuri_Text/Yuri_Text_Chinese.xml</File>
      <File>Yuri_Text/Yuri_Text_Loading.xml</File>
    </UpdateText>
    <UpdateIcons id="Icons">
      <Criteria>YuriCriteria</Criteria>
      <File>Core/NewIcons.xml</File>
    </UpdateIcons>
  </InGameActions>
